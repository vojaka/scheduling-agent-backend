# Copy to .env and fill in real values. .env is gitignored — never commit secrets.
# docker-compose.yml reads these; the ${VAR:?...} entries are required.

# Postgres (shared by db, postgrest, backend, metabase)
POSTGRES_PASSWORD=

# PostgREST
PGRST_JWT_SECRET=

# Backend
APP_API_KEY=
BUBBLE_API_TOKEN=
GEMINI_API_KEY=
METABASE_EMBED_SECRET=

# Auth0 Management API (optional) — enables emailing account-setup invites to new
# workers via POST /api/users/invite. Leave blank to create pending memberships
# without sending the email. Use an M2M app authorized for the Management API
# with the create:users scope.
AUTH0_MGMT_DOMAIN=
AUTH0_MGMT_CLIENT_ID=
AUTH0_MGMT_CLIENT_SECRET=
# Optional (legacy PostgREST sync — unused after the JPA sync rewrite)
SUPABASE_API_KEY=

# Payments — Montonio (Stargate API)
MONTONIO_ACCESS_KEY=
MONTONIO_SECRET_KEY=
# Optional overrides:
# MONTONIO_BASE_URL=https://sandbox-stargate.montonio.com/api
# MONTONIO_ENABLED_METHODS=cardPayments,paymentInitiation

# Payments — EveryPay (APIv4)
EVERYPAY_API_USERNAME=
EVERYPAY_API_SECRET=
EVERYPAY_ACCOUNT_NAME=
# Optional overrides:
# EVERYPAY_BASE_URL=https://igw-demo.every-pay.com/api/v4
# EVERYPAY_ENABLED_METHODS=card
# PAYMENTS_DEFAULT_PROVIDER=montonio
